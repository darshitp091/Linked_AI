# ==============================================================================
# LinkedAI - Environment Variables Template
# ==============================================================================
# Copy this file to .env.local and fill in your actual values
# For Vercel deployment, add these variables in: Settings > Environment Variables
# ==============================================================================

# ------------------------------------------------------------------------------
# REQUIRED - Supabase (Database & Authentication)
# ------------------------------------------------------------------------------
# Get these from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ------------------------------------------------------------------------------
# REQUIRED - Groq AI (Content Generation)
# ------------------------------------------------------------------------------
# Get free API key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key

# ------------------------------------------------------------------------------
# REQUIRED - LinkedIn OAuth (Social Login & Posting)
# ------------------------------------------------------------------------------
# Create app at: https://www.linkedin.com/developers/apps
# Redirect URI: https://your-domain.vercel.app/api/linkedin-oauth/callback
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
LINKEDIN_REDIRECT_URI=https://your-domain.vercel.app/api/linkedin-oauth/callback

# ------------------------------------------------------------------------------
# REQUIRED - NextAuth (Authentication)
# ------------------------------------------------------------------------------
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret_key
# Your production URL (update after Vercel deployment)
NEXTAUTH_URL=http://localhost:3000

# ------------------------------------------------------------------------------
# OPTIONAL - JWT Secret (for token signing)
# ------------------------------------------------------------------------------
# Generate with: openssl rand -base64 32
JWT_SECRET=your_jwt_secret

# ------------------------------------------------------------------------------
# Environment (set automatically by Vercel)
# ------------------------------------------------------------------------------
# NODE_ENV=production
